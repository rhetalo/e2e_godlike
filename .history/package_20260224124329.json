/**
 * ============================================================================================
 * КОНФИГУРАЦИЯ NPM ПРОЕКТА (MANIFEST)
 * ============================================================================================
 * 
 * Этот файл содержит метаданные проекта и список зависимостей.
 * 
 * ДЛЯ НАЧИНАЮЩЕГО QA:
 * --------------------
 * npm (Node Package Manager) - менеджер пакетов для Node.js
 * package.json - главный файл проекта, который описывает:
 * - Название проекта и версию
 * - Какие библиотеки (зависимости) нужны для работы
 * - npm-скрипты для запуска команд
 * 
 * Основные команды npm:
 * - npm install - установить все зависимости из package.json
 * - npx playwright test - запустить тесты Playwright
 * ============================================================================================
 */

{
  // name - название проекта
  // Обычно используется kebab-case (нижние подчеркивания, дефисы)
  "name": "godlike-test-2",

  // version - текущая версия проекта
  // Используется семантическое версионирование: MAJOR.MINOR.PATCH
  // - MAJOR - критические изменения (несовместимые)
  // - MINOR - новый функционал (обратная совместимость)
  // - PATCH - исправления багов
  "version": "1.0.0",

  // description - краткое описание проекта
  // Что делает этот проект
  "description": "npx playwright test",

  // main - точка входа для Node.js приложения
  // Если бы это был JS-проект, npm искала бы этот файл при require()
  // Для тестового проекта не так важно
  "main": "index.js",

  // keywords - ключевые слова для поиска в npm реестре
  // Помогает другим разработчикам найти проект
  "keywords": [],

  // author - автор проекта
  // Может быть имя, email или организация
  "author": "",

  // license - лицензия проекта
  // Определяет, как другие могут использовать ваш код
  // ISC - простая лицензия, похожая на MIT
  "license": "ISC",

  // devDependencies - зависимости, нужные только для разработки
  // Эти пакеты не нужны в продакшене (на рабочем сервере)
  // Устанавливаются командой: npm install --save-dev
  "devDependencies": {
    // @playwright/test - основная библиотека для написания и запуска E2E тестов
    // ^1.58.2 - версия (^ означает "совместимая с 1.58.2", т.е. 1.x.x где x >= 58.2)
    // Playwright позволяет:
    // - Писать автоматические тесты на TypeScript/JavaScript
    // - Запускать тесты в реальных браузерах (Chrome, Firefox, Safari)
    // - Делать скриншоты и записывать видео
    // - Отлаживать тесты с помощью Trace Viewer
    "@playwright/test": "^1.58.2",

    // @types/node - TypeScript типы для Node.js
    // Позволяет использовать TypeScript с Node.js API (process, Buffer, и т.д.)
    // ^25.2.1 - версия
    "@types/node": "^25.2.1"
  },

  // directories - директории проекта
  // Не влияет на работу npm, но документирует структуру проекта
  "directories": {
    // test - где находятся тесты (для документации)
    "test": "tests"
  },

  // type - тип модулей Node.js
  // "commonjs" - классический формат (require/module.exports)
  // "module" - современный ES Modules (import/export)
  // В данном проекте используется CommonJS
  "type": "commonjs",

  // scripts - npm-скрипты (пользовательские команды)
  // Запускаются командой: npm run <имя-скрипта>
  // Пример: npm run test запустит "playwright test"
  // Здесь scripts пустой объект, значит используются встроенные команды Playwright
  "scripts": {}
}
